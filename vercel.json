{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "../index.html",
          "../admin.html",
          "../referral.html",
          "../*.png",
          "../*.jpg",
          "../*.mp4",
          "../*.pdf"
        ]
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/index.js"
    }
  ]
}
