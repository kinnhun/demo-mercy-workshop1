{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "server.js"
    },
    {
      "src": "/admin",
      "dest": "admin.html"
    },
    {
      "src": "/referral/(.*)",
      "dest": "referral.html"
    },
    {
      "src": "/(.*)",
      "dest": "$1"
    }
  ]
}
