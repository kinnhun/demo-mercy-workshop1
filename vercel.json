{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api/index.js"
    },
    {
      "src": "/referral/(.*)",
      "dest": "/referral.html"
    },
    {
      "src": "/admin",
      "dest": "/admin.html"
    },
    {
      "handle": "filesystem"
    }
  ]
}
